# ── Autenticación (NextAuth) ──────────────────────────────────────────────
# Secreto para cifrar las sesiones JWT de NextAuth
NEXTAUTH_SECRET=your-secret-at-least-32-chars-long
# URL base de la aplicación (para callbacks de auth)
NEXTAUTH_URL=http://localhost:3000

# ── API ───────────────────────────────────────────────────────────────────
# URL del backend (sin /api)
NEXT_PUBLIC_URL_API=https://bustoke-admin-backend.onrender.com

# ── JWT (opcional) ────────────────────────────────────────────────────────
# Secreto adicional para validar JWT del backend (si se requiere)
# JWT_SECRET_API=
